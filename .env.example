# --- Application / HTTP ---
# Default dev port is 8010 (see README / Dockerfile); override when running uvicorn locally.
# SERVER_PORT=8010
# LOG_LEVEL=INFO
# Comma-separated origins for browser clients. Avoid * in production.
# Next.js dev server (include when using frontend/): http://localhost:3000
# CORS_ALLOW_ORIGINS=http://localhost:3000
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
# TRUSTED_HOSTS=api.example.com,localhost
# Optional: require X-API-Key on /v1/query and WebSocket (comma-separated accepted keys)
# API_KEYS=
# Per-IP rate limit for POST /v1/query (0 = disabled)
# RATE_LIMIT_PER_MINUTE=60

# Payload guardrails
# MAX_USER_QUERY_CHARS=16000
# MAX_THREAD_ID_CHARS=128
# MAX_DOCUMENT_IDS=50
# MAX_DOCUMENT_ID_CHARS=256
# MAX_WS_MESSAGE_BYTES=262144

# --- OpenRouter (LLM via OpenAI-compatible API) ---
# https://openrouter.ai/
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_TITLE=Legal Multi-Agent Platform
# OPENROUTER_TIMEOUT_SEC=120

# Per-role model IDs (defaults are sensible if unset)
# LEGAL_LLM_MODEL_RESEARCHER=openai/gpt-4o-mini
# LEGAL_LLM_MODEL_COUNSEL=anthropic/claude-3.5-sonnet
# LEGAL_LLM_MODEL_AUDITOR=openai/gpt-4o-mini
# LEGAL_LLM_MAX_TOKENS_COUNSEL=3072

# --- Database (optional Phase 2) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/legal_intel
