# FastAPI origin (no trailing slash)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010

# Clerk — copy from https://dashboard.clerk.com/ last-active?path=api-keys
# Never commit real keys; use .env.local (gitignored).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: only for Clerk middleware dynamic secret propagation (see Clerk docs).
# Not required when using CLERK_SECRET_KEY in .env as usual.
# CLERK_ENCRYPTION_KEY=

# Optional: full-page sign-in/up (defaults work if these match your routes)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional: Clerk Billing (beta) — plan ID from Dashboard after enabling Billing
# NEXT_PUBLIC_CLERK_CHECKOUT_PLAN_ID=
